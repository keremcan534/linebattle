{
  "name": "linebattle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based real-time WW2 operational strategy game on a continuous real-world map.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit false --emitDeclarationOnly false --pretty",
    "lint": "eslint . --ext .ts,.tsx,.mjs",
    "data:prepare": "node scripts/prepare-map-data.mjs"
  },
  "dependencies": {
    "pixi.js": "^8.6.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
